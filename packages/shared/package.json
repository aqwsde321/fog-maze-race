{
  "name": "@fog-maze-race/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./contracts/realtime": {
      "types": "./dist/contracts/realtime.d.ts",
      "default": "./dist/contracts/realtime.js"
    },
    "./contracts/snapshots": {
      "types": "./dist/contracts/snapshots.d.ts",
      "default": "./dist/contracts/snapshots.js"
    },
    "./contracts/admin-maps": {
      "types": "./dist/contracts/admin-maps.d.ts",
      "default": "./dist/contracts/admin-maps.js"
    },
    "./contracts/server-health": {
      "types": "./dist/contracts/server-health.d.ts",
      "default": "./dist/contracts/server-health.js"
    },
    "./domain/grid-position": {
      "types": "./dist/domain/grid-position.d.ts",
      "default": "./dist/domain/grid-position.js"
    },
    "./domain/player-marker-shape": {
      "types": "./dist/domain/player-marker-shape.d.ts",
      "default": "./dist/domain/player-marker-shape.js"
    },
    "./domain/result-entry": {
      "types": "./dist/domain/result-entry.d.ts",
      "default": "./dist/domain/result-entry.js"
    },
    "./domain/room-bot-strategy": {
      "types": "./dist/domain/room-bot-strategy.d.ts",
      "default": "./dist/domain/room-bot-strategy.js"
    },
    "./domain/status": {
      "types": "./dist/domain/status.d.ts",
      "default": "./dist/domain/status.js"
    },
    "./maps/map-definitions": {
      "types": "./dist/maps/map-definitions.d.ts",
