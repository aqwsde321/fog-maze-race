{
  "name": "fog-maze-race",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @fog-maze-race/shared --filter @fog-maze-race/server --filter @fog-maze-race/web dev",
    "build": "pnpm --filter @fog-maze-race/shared build && pnpm --filter @fog-maze-race/server build && pnpm --filter @fog-maze-race/web build",
    "start": "pnpm --filter @fog-maze-race/server start",
    "race:join": "pnpm --filter @fog-maze-race/web race:join",
    "race:explore": "pnpm --filter @fog-maze-race/web race:explore",
    "race:fill": "pnpm --filter @fog-maze-race/web race:fill",
    "docker:build": "docker compose build",
    "docker:up": "bash ./scripts/docker/start.sh",
    "docker:stop": "bash ./scripts/docker/stop.sh",
    "docker:down": "bash ./scripts/docker/remove.sh",
    "docker:remove": "bash ./scripts/docker/remove.sh",
    "docker:logs": "bash ./scripts/docker/logs.sh",
    "docker:ps": "bash ./scripts/docker/status.sh",
    "test": "pnpm --filter @fog-maze-race/shared test && pnpm --filter @fog-maze-race/server test && pnpm --filter @fog-maze-race/web test && pnpm test:scripts",
    "test:scripts": "node --test tests/scripts/docker-scripts.test.mjs tests/scripts/race-bot.test.mjs tests/scripts/race-bot-explorer.test.mjs tests/scripts/race-bot-fill.test.mjs",
    "typecheck": "pnpm --filter @fog-maze-race/shared typecheck && pnpm --filter @fog-maze-race/server typecheck && pnpm --filter @fog-maze-race/web typecheck",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
